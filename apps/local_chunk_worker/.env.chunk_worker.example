# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rag_prod

# Redis
REDIS_URI=redis://localhost:6379
REDIS_CHUNK_STREAM=rag:chunks
REDIS_CHUNK_CONSUMER_GROUP=document_chunking
REDIS_CHUNK_BLOCK_MS=30000
REDIS_CHUNK_RECLAIM_IDLE_MS=120000
REDIS_CHUNK_RECLAIM_BATCH_SIZE=10
REDIS_CHUNK_RECLAIM_INTERVAL_SECONDS=30

# AWS S3
S3_BUCKET_NAME=rag-prod-documents-bucket
AWS_ACCESS_KEY_ID=mock_access_key_id
AWS_SECRET_ACCESS_KEY=mock_secret_access_key
AWS_REGION=us-east-1

# Chunking
CHUNK_SIZES=756,324

# Worker Scaling
MAX_CONCURRENT_TASKS=5

# Mongo collections
COLL_DOCUMENTS=documents
COLL_CHUNKS=chunks

# Gemini embeddings
GOOGLE_API_KEY=
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2
GEMINI_EMBEDDING_OUTPUT_DIMENSIONALITY=512
GEMINI_EMBEDDING_DISPLAY_NAME=local_chunk_worker_inline_embedding_run
GEMINI_EMBEDDING_MAX_INLINE_BYTES=20971520
