# ==========================================
# Chunk Worker Configuration
# ==========================================

# Database & Redis Settings
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rag_prod
REDIS_URI=redis://localhost:6379
REDIS_CHUNK_STREAM=rag:chunks

# Redis Stream Polling & Consumer Settings
REDIS_CHUNK_CONSUMER_GROUP=document_chunking
REDIS_CHUNK_BLOCK_MS=30000
REDIS_CHUNK_RECLAIM_IDLE_MS=120000
REDIS_CHUNK_RECLAIM_BATCH_SIZE=10
REDIS_CHUNK_RECLAIM_INTERVAL_SECONDS=30

# AWS S3 Settings (Used to fetch documents during chunking)
S3_BUCKET_NAME=rag-prod-documents-bucket
AWS_ACCESS_KEY_ID=mock_access_key_id
AWS_SECRET_ACCESS_KEY=mock_secret_access_key
AWS_REGION=us-east-1

# LlamaIndex chunking configuration
# Comma-separated list of chunk sizes
CHUNK_SIZES=756,324
MAX_CONCURRENT_TASKS=5

# Collections
COLL_DOCUMENTS=documents
COLL_CHUNKS=chunks

# Landing AI Configuration (Used if parsing PDFs via Landing AI Vision)
LANDING_AI_API_KEY=your_landing_ai_api_key_here
LANDING_AI_BASE_URL=https://api.va.landing.ai/v1/ade

# Gemini Embeddings Configuration
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2
GEMINI_EMBEDDING_OUTPUT_DIMENSIONALITY=512
GEMINI_EMBEDDING_DISPLAY_NAME=chunk_worker_inline_embedding_run
GEMINI_EMBEDDING_MAX_INLINE_BYTES=20971520

# Worker Mode (local | external | both)
CHUNK_WORKER_MODE=both
