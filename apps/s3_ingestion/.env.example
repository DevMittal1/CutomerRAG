# ==========================================
# S3 Ingestion Worker Configuration
# ==========================================

# Database & Redis Connections
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rag_prod
REDIS_URI=redis://localhost:6379
REDIS_CHUNK_STREAM=rag:chunks

# AWS Configuration (For S3 document reading and SQS task polling)
AWS_ACCESS_KEY_ID=mock_access_key_id
AWS_SECRET_ACCESS_KEY=mock_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=rag-prod-documents-bucket

# AWS SQS Queue Settings
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/rag-ingestion-queue
AWS_SQS_WAIT_TIME_SECONDS=20
AWS_SQS_VISIBILITY_TIMEOUT=30

# Worker Scale settings
MAX_CONCURRENT_TASKS=5

# Collection Names
COLL_DOCUMENTS=documents

# Landing AI Configuration (Used if document routing requires layout/vision extraction)
LANDING_AI_API_KEY=your_landing_ai_api_key_here
LANDING_AI_BASE_URL=https://api.va.landing.ai/v1/ade
