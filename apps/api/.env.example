# ==========================================
# RAG API Server Configuration
# ==========================================

# Server Binding Settings
HOST=127.0.0.1
PORT=8000

# Database & Redis Settings
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rag_prod
REDIS_URI=redis://localhost:6379

# JWT Authentication
JWT_SECRET_KEY=949f57912bbbc4f7831f24d45a98bf24c5b96677f98d4076f7bb8f1d82121de4
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AWS S3 Settings (For document storage and generating pre-signed URLs)
AWS_ACCESS_KEY_ID=mock_access_key_id
AWS_SECRET_ACCESS_KEY=mock_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=rag-prod-documents-bucket

# CORS Settings (JSON array or comma-separated list)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Global Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BYPASS_IPS=["127.0.0.1", "::1"]

# Application Environment (development, testing, production)
ENV=production

# Landing AI Configuration (Used if external parsing is routed)
LANDING_AI_API_KEY=
LANDING_AI_BASE_URL=https://api.va.landing.ai/v1/ade

# Gemini Chat & Embeddings Settings
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_CHAT_MODEL=gemini-3.5-flash
RAG_QUERY_EMBEDDING_MODEL=text-embedding-004
RAG_QUERY_EMBEDDING_OUTPUT_DIMENSIONALITY=512

# Cohere Reranking Settings (Optional unless RAG_REQUIRE_COHERE_RERANK is true)
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5
RAG_REQUIRE_COHERE_RERANK=false

# Qdrant Vector Database Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=document_chunks
QDRANT_VECTOR_SIZE=512
QDRANT_DISTANCE=Cosine
QDRANT_DENSE_VECTOR_NAME=
QDRANT_SPARSE_VECTOR_NAME=
QDRANT_PREFER_GRPC=true

# RAG & Retrieval Search Parameters
RAG_ENABLE_SPARSE_RETRIEVAL=true
RAG_SPARSE_MODEL_NAME=prithvida/Splade_PP_en_v1
RAG_RETRIEVE_LIMIT_DENSE=50
RAG_RETRIEVE_LIMIT_SPARSE=50
RAG_RETRIEVE_LIMIT_FINAL=50
RAG_RERANK_TOP_N=8
RAG_MAX_CONTEXT_CHUNKS=6
RAG_MAX_FILTER_DOCUMENT_IDS=1000
RAG_GENERATION_MAX_OUTPUT_TOKENS=2048
RAG_GENERATION_TEMPERATURE=0.2

# Timeouts & RAG Trace settings
RAG_REQUEST_TIMEOUT_SECONDS=45.0
RAG_QDRANT_TIMEOUT_SECONDS=10
RAG_EVAL_TRACE_ENABLED=true
RAG_EVAL_TRACE_COLLECTION=rag_evaluation_traces
RAG_EVAL_TRACE_MAX_CONTEXTS=12
RAG_EVAL_TRACE_MAX_CONTEXT_CHARS=4000
