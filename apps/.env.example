# Server Binding Settings
HOST=0.0.0.0
PORT=8000

# Database Settings
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rag_prod
REDIS_URI = redis://localhost:6379

# Authentication Settings
JWT_SECRET_KEY=jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REDIS_CHUNK_STREAM=rag:chunks

# AWS S3 Settings (Generate offline pre-signed URLs)
AWS_ACCESS_KEY_ID=mock_access_key_id
AWS_SECRET_ACCESS_KEY=mock_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=rag-prod-documents-bucket

# CORS Settings (JSON array or comma-separated origins)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Global Rate Limiting Settings
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BYPASS_IPS=["127.0.0.1", "::1"]

# Application Environment (development, testing, production)
ENV=production

# Landing AI Configuration
LANDING_AI_API_KEY=your_landing_ai_api_key_here
LANDING_AI_BASE_URL=https://api.va.landing.ai/v1/ade

# Gemini Embeddings
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=document_chunks
QDRANT_VECTOR_SIZE=512
QDRANT_DISTANCE=Cosine
QDRANT_DENSE_VECTOR_NAME=
QDRANT_SPARSE_VECTOR_NAME=
QDRANT_SPARSE_ON_DISK=false

# Embedding Poll Worker
EMBEDDING_POLL_INTERVAL_SECONDS=30
EMBEDDING_POLL_CLAIM_LIMIT=50
EMBEDDING_POLL_CONCURRENCY=10
EMBEDDING_LOCK_TIMEOUT_SECONDS=120
EMBEDDING_JOB_TIMEOUT_SECONDS=86400
EMBEDDING_BASE_RETRY_SECONDS=30
EMBEDDING_BACKOFF_MULTIPLIER=1.5
EMBEDDING_MAX_RETRY_SECONDS=900
EMBEDDING_JITTER_SECONDS=5
EMBEDDING_POLL_RUN_ONCE=false
