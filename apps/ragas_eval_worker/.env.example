# ==========================================
# Ragas Evaluation Worker Configuration
# ==========================================

# Database Settings
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rag_prod

# Google / Gemini API Keys (GEMINI_API_KEY takes precedence if both are defined)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Evaluation Settings
RAG_EVAL_TRACE_COLLECTION=rag_evaluation_traces
RAGAS_EVAL_MODEL=gemini-2.0-flash
RAGAS_EVAL_EMBEDDING_MODEL=text-embedding-004

# Polling & Evaluation Batch Settings
RAGAS_EVAL_POLL_INTERVAL_SECONDS=15.0
RAGAS_EVAL_BATCH_SIZE=4
RAGAS_EVAL_LOCK_TIMEOUT_SECONDS=300
RAGAS_EVAL_MAX_ATTEMPTS=5
RAGAS_EVAL_RUN_ONCE=false
