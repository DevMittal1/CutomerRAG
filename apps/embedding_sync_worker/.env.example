# ==========================================
# Embedding Sync Worker Configuration
# ==========================================

# Database Settings
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rag_prod

# Collections
COLL_DOCUMENTS=documents
COLL_CHUNKS=chunks

# Google / Gemini API key
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=document_chunks
QDRANT_VECTOR_SIZE=512
QDRANT_DISTANCE=Cosine
QDRANT_DENSE_VECTOR_NAME=
QDRANT_SPARSE_VECTOR_NAME=
QDRANT_SPARSE_ON_DISK=false
QDRANT_UPSERT_BATCH_SIZE=64

# Worker Polling & Concurrency settings
EMBEDDING_POLL_INTERVAL_SECONDS=30.0
EMBEDDING_POLL_CLAIM_LIMIT=50
EMBEDDING_POLL_CONCURRENCY=10
EMBEDDING_LOCK_TIMEOUT_SECONDS=120
EMBEDDING_JOB_TIMEOUT_SECONDS=86400
EMBEDDING_BASE_RETRY_SECONDS=30.0
EMBEDDING_BACKOFF_MULTIPLIER=1.5
EMBEDDING_MAX_RETRY_SECONDS=900.0
EMBEDDING_JITTER_SECONDS=5.0
EMBEDDING_POLL_RUN_ONCE=false
