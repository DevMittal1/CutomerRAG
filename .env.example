# ==============================================================================
# CustomerRAG Master Environment Configuration File
# ==============================================================================
# You can copy this file to .env inside the apps/ directory or the root directory.
# All RAG services & workers are configured to load variables from multiple levels.

# ------------------------------------------------------------------------------
# 1. Server Binding Settings (API Service)
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
ENV=production

# ------------------------------------------------------------------------------
# 2. Database & Redis Connectivity Settings
# ------------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rag_prod

REDIS_URI=redis://localhost:6379
REDIS_CHUNK_STREAM=rag:chunks

# ------------------------------------------------------------------------------
# 3. Authentication & CORS Settings (API Service)
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS Settings (JSON array or comma-separated origins)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Global Rate Limiting Settings
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BYPASS_IPS=["127.0.0.1", "::1"]

# ------------------------------------------------------------------------------
# 4. AWS Services (S3, SQS)
# ------------------------------------------------------------------------------
# AWS S3 Settings (Document reading, writing & presigned URL generation)
S3_BUCKET_NAME=rag-prod-documents-bucket
AWS_ACCESS_KEY_ID=mock_access_key_id
AWS_SECRET_ACCESS_KEY=mock_secret_access_key
AWS_REGION=us-east-1

# AWS SQS Settings (S3 Ingestion Worker)
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/rag-ingestion-queue
AWS_SQS_WAIT_TIME_SECONDS=20
AWS_SQS_VISIBILITY_TIMEOUT=30

# ------------------------------------------------------------------------------
# 5. Gemini & Google AI Settings
# ------------------------------------------------------------------------------
# Google API Keys
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Embedding Configuration
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2
GEMINI_EMBEDDING_OUTPUT_DIMENSIONALITY=512
GEMINI_EMBEDDING_DISPLAY_NAME=chunk_worker_inline_embedding_run
GEMINI_EMBEDDING_MAX_INLINE_BYTES=20971520

# Chat & API Retrieval Models
GEMINI_CHAT_MODEL=gemini-3.5-flash
RAG_QUERY_EMBEDDING_MODEL=text-embedding-004
RAG_QUERY_EMBEDDING_OUTPUT_DIMENSIONALITY=512

# ------------------------------------------------------------------------------
# 6. Cohere Reranking Configuration (Optional)
# ------------------------------------------------------------------------------
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5
RAG_REQUIRE_COHERE_RERANK=false

# ------------------------------------------------------------------------------
# 7. Qdrant Vector Database Settings
# ------------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=document_chunks
QDRANT_VECTOR_SIZE=512
QDRANT_DISTANCE=Cosine
QDRANT_DENSE_VECTOR_NAME=
QDRANT_SPARSE_VECTOR_NAME=
QDRANT_SPARSE_ON_DISK=false
QDRANT_PREFER_GRPC=true
QDRANT_UPSERT_BATCH_SIZE=64

# ------------------------------------------------------------------------------
# 8. Landing AI Document Parser Configuration (Optional)
# ------------------------------------------------------------------------------
LANDING_AI_API_KEY=your_landing_ai_api_key_here
LANDING_AI_BASE_URL=https://api.va.landing.ai/v1/ade

# ------------------------------------------------------------------------------
# 9. Ingestion & Chunk Worker Scale/Mode Settings
# ------------------------------------------------------------------------------
MAX_CONCURRENT_TASKS=5
CHUNK_WORKER_MODE=both
CHUNK_SIZES=756,324

# Redis Stream Consumer Group Settings
REDIS_CHUNK_CONSUMER_GROUP=document_chunking
REDIS_CHUNK_BLOCK_MS=30000
REDIS_CHUNK_RECLAIM_IDLE_MS=120000
REDIS_CHUNK_RECLAIM_BATCH_SIZE=10
REDIS_CHUNK_RECLAIM_INTERVAL_SECONDS=30

# MongoDB Collection overrides
COLL_DOCUMENTS=documents
COLL_CHUNKS=chunks

# ------------------------------------------------------------------------------
# 10. Embedding Poll Worker Settings
# ------------------------------------------------------------------------------
EMBEDDING_POLL_INTERVAL_SECONDS=30.0
EMBEDDING_POLL_CLAIM_LIMIT=50
EMBEDDING_POLL_CONCURRENCY=10
EMBEDDING_LOCK_TIMEOUT_SECONDS=120
EMBEDDING_JOB_TIMEOUT_SECONDS=86400
EMBEDDING_BASE_RETRY_SECONDS=30.0
EMBEDDING_BACKOFF_MULTIPLIER=1.5
EMBEDDING_MAX_RETRY_SECONDS=900.0
EMBEDDING_JITTER_SECONDS=5.0
EMBEDDING_POLL_RUN_ONCE=false

# ------------------------------------------------------------------------------
# 11. Ragas Evaluation Worker Settings
# ------------------------------------------------------------------------------
RAG_EVAL_TRACE_ENABLED=true
RAG_EVAL_TRACE_COLLECTION=rag_evaluation_traces
RAG_EVAL_TRACE_MAX_CONTEXTS=12
RAG_EVAL_TRACE_MAX_CONTEXT_CHARS=4000

RAGAS_EVAL_MODEL=gemini-2.0-flash
RAGAS_EVAL_EMBEDDING_MODEL=text-embedding-004
RAGAS_EVAL_POLL_INTERVAL_SECONDS=15.0
RAGAS_EVAL_BATCH_SIZE=4
RAGAS_EVAL_LOCK_TIMEOUT_SECONDS=300
RAGAS_EVAL_MAX_ATTEMPTS=5
RAGAS_EVAL_RUN_ONCE=false

# ------------------------------------------------------------------------------
# 12. RAG API Search & Retrieval Settings
# ------------------------------------------------------------------------------
RAG_ENABLE_SPARSE_RETRIEVAL=true
RAG_SPARSE_MODEL_NAME=prithvida/Splade_PP_en_v1
RAG_RETRIEVE_LIMIT_DENSE=50
RAG_RETRIEVE_LIMIT_SPARSE=50
RAG_RETRIEVE_LIMIT_FINAL=50
RAG_RERANK_TOP_N=8
RAG_MAX_CONTEXT_CHUNKS=6
RAG_MAX_FILTER_DOCUMENT_IDS=1000
RAG_GENERATION_MAX_OUTPUT_TOKENS=2048
RAG_GENERATION_TEMPERATURE=0.2
RAG_REQUEST_TIMEOUT_SECONDS=45.0
RAG_QDRANT_TIMEOUT_SECONDS=10
